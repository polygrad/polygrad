{
  "name": "polygrad",
  "version": "0.2.0",
  "description": "Tensor computation library with native and WASM backends",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "dist/",
    "wasm/",
    "csrc/",
    "napi_api.c",
    "binding.gyp",
    "scripts/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepack": "node scripts/prepack.js",
    "install": "node scripts/install-native.js",
    "build:native": "node scripts/sync-csrc.js && node-gyp rebuild",
    "build:browser": "bash scripts/build-browser.sh",
    "test": "node test/test_wasm.js"
  },
  "gypfile": true,
  "sideEffects": false,
  "devDependencies": {
    "esbuild": "^0.27.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
